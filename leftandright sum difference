class Solution {
    public int[] leftRightDifference(int[] nums) {
        int n=nums.length;
        int[] ans=new int[n];
        int left=0;
        int sum=0;
        for(int i=0;i<n;i++)
        {   sum+=nums[i];
        }
        for(int i=0;i<n;i++)
        {  int right=sum-left-nums[i];
            ans[i]=Math.abs(left-right);
            left+=nums[i];
        }
        return ans;
        
    }
}
